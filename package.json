{
  "name": "astro-charts-br",
  "version": "0.1.0",
  "description": "Componentes Vue para astrocartografia, mapa natal, astrologia horária e Matriz do Destino.",
  "type": "module",
  "author": "Priscila Floriano",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "ADR.md",
    "docs"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "astrologia",
    "astrology",
    "mapa-astral",
    "astrocartografia",
    "astrocartography",
    "astrologia-horaria",
    "vue",
    "componentes"
  ],
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc -b",
    "build": "vue-tsc -b && vite build && vue-tsc -p tsconfig.build.json",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:demo:inline": "npm run build:demo && node scripts/build-inline-demo.mjs",
    "generate:astrocartography": "node scripts/generate-astrocartography-data.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^24.13.2",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "astronomy-engine": "^2.1.19",
    "d3-geo": "^3.1.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "topojson-client": "^3.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.5",
    "world-atlas": "^2.0.2"
  }
}
